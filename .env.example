# =====================================================================
#  Muniz Platform — Environment Variables
# =====================================================================
#  Automatic bootstrap:
#    ./scripts/docker-up.sh
#
#  Or copy this file to .env and edit manually:
#    cp .env.example .env
# =====================================================================

# ---------- Database ----------
DB_USER=muniz_app
DB_PASSWORD=troque-esta-senha
DB_NAME=muniz_platform

# ---------- Domains (Caddy auto-SSL) ----------
# For local automatic setup, .localhost works well with Caddy.
# In production, point these domains to your server public IP.
TRADING_DOMAIN=app.localhost
AFILIADOS_DOMAIN=afiliados.localhost
ADMIN_DOMAIN=admin.localhost

# ---------- Site / Branding ----------
# SITE_DOMAIN is used to generate the admin email: admin@<SITE_DOMAIN>
SITE_DOMAIN=localhost
SITE_NAME="Muniz Platform"

# ---------- Admin ----------
# Password for the auto-created SUPER_ADMIN account.
# Email will be: admin@<SITE_DOMAIN>
ADMIN_PASSWORD=TroqueEstaSenha123

# ---------- Market Data ----------
# Tiingo API key (get one at https://www.tiingo.com/)
# Supports crypto + forex via REST and WebSocket.
TIINGO_API_KEY=

# ---------- Auth ----------
# Shared secret for JWT tokens (afiliados + admin).
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=gere-uma-chave-secreta-aqui
