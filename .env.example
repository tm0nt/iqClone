# =====================================================================
#  Muniz Platform — Environment Variables
# =====================================================================
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# =====================================================================

# ---------- Database ----------
DB_USER=brx
DB_PASSWORD=SuaSenhaForteAqui
DB_NAME=trading

# ---------- Domains (Caddy auto-SSL) ----------
# These MUST point to your server's public IP for Let's Encrypt to work.
TRADING_DOMAIN=app.seudominio.com
AFILIADOS_DOMAIN=afiliados.seudominio.com
ADMIN_DOMAIN=admin.seudominio.com

# ---------- Site / Branding ----------
# SITE_DOMAIN is used to generate the admin email: admin@<SITE_DOMAIN>
SITE_DOMAIN=seudominio.com
SITE_NAME=MinhaPlatforma

# ---------- Admin ----------
# Password for the auto-created SUPER_ADMIN account.
# Email will be: admin@<SITE_DOMAIN>
ADMIN_PASSWORD=TroqueEstaSenha123!

# ---------- Market Data ----------
# Tiingo API key (get one at https://www.tiingo.com/)
# Supports crypto + forex via REST and WebSocket.
TIINGO_API_KEY=

# ---------- Auth ----------
# Shared secret for JWT tokens (afiliados + admin).
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=gere-uma-chave-secreta-aqui
